# DashScope API Key（必填）
# 用于所有大模型调用：图片理解、ASR、Embedding、问答生成
DASHSCOPE_API_KEY="your_dashscope_api_key"

# ============================
# Agent 模型配置（按需替换）
# ============================

# 图片理解模型（ImageAgent）
# 作用：识别帖子图片并生成描述文本
# 常用：qwen-vl-plus 或者支持视觉理解的qwen模型
IMAGE_AGENT_MODEL="qwen3.5-flash"

# 音频转写模型（AudioAgent）
# 作用：将帖子视频音频转写为文本
# 常用：paraformer-v2
AUDIO_AGENT_MODEL="paraformer-v2"

# 向量模型（统一用于入库 + 检索）
# 作用：文本向量化，影响召回质量与速度
# 常用：text-embedding-v3 / text-embedding-v4
EMBEDDING_MODEL="text-embedding-v4"

# ============================
# 检索 / 问答模型配置
# ============================

# Query Parser 模型
# 作用：将用户问题解析为结构化过滤条件（game_id、版本号、官方标记等）
QUERY_PARSER_MODEL="qwen3.6-plus"

# 最终回答生成模型
# 作用：基于召回上下文生成最终回答
ANSWER_MODEL="qwen3.6-plus"

# ============================
# Agent 行为参数（性能/成本）
# ============================

# 每个帖子最多处理图片数
# 数值越大：信息更全，但耗时更长、成本更高
# 建议范围：1~5
IMAGE_AGENT_MAX_IMAGES_PER_POST=3

# 单帖内图片并发数（仅当该帖有多图时生效）
# 数值越大：更快但更易触发限流
# 建议范围：1~4
IMAGE_AGENT_INTERNAL_WORKERS=3
